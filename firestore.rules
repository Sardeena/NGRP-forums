rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "sardena449@gmail.com")
      );
    }

    function isStaff() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'moderator']);
    }

    function isNotBanned() {
      return !isAuthenticated() || 
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == false;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email', 'role', 'color', 'joinedAt']) &&
             data.uid is string && 
             data.username is string && 
             data.email is string &&
             data.role is string &&
             data.color is string &&
             data.joinedAt is string &&
             (!('signature' in data) || (data.signature is string)) &&
             (!('profileViews' in data) || (data.profileViews is int)) &&
             (!('postCount' in data) || (data.postCount is int)) &&
             (!('reputation' in data) || (data.reputation is int)) &&
             (!('lastMessageAt' in data) || (data.lastMessageAt is int)) &&
             (!('isBanned' in data) || (data.isBanned is bool)) &&
             (!('banReason' in data) || (data.banReason is string));
    }

    function isValidLikeUpdate(resource, request) {
      let oldLikes = 'likes' in resource.data ? resource.data.likes : [];
      let newLikes = 'likes' in request.resource.data ? request.resource.data.likes : [];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
             (
               (newLikes.size() == oldLikes.size() + 1 && newLikes.hasAll(oldLikes) && newLikes.hasAll([request.auth.uid])) ||
               (newLikes.size() == oldLikes.size() - 1 && oldLikes.hasAll(newLikes) && oldLikes.hasAll([request.auth.uid])) ||
               (newLikes.size() == oldLikes.size() && newLikes.hasAll(oldLikes))
             );
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == 'member';
      allow update: if (
        (isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data)) || 
        isAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews'])) ||
        (isAuthenticated() && isNotBanned() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastMessageAt', 'postCount', 'reputation'])) ||
        (isStaff() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['isBanned', 'banReason', 'role', 'postCount', 'reputation']))
      );
      allow delete: if isAdmin();
    }

    function isValidThread(data) {
      return data.keys().hasAll(['title', 'content', 'author', 'authorUid', 'subForum', 'createdAt']) &&
             data.title is string && 
             data.content is string && 
             data.authorUid == request.auth.uid;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['threadId', 'content', 'author', 'authorUid', 'timestamp']) &&
             data.threadId is string &&
             data.content is string &&
             data.authorUid == request.auth.uid;
    }

    match /threads/{threadId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned() && isValidThread(request.resource.data);
      allow update: if (
        (isAuthenticated() && isOwner(resource.data.authorUid) && isValidThread(request.resource.data) && 
         (!('isLocked' in request.resource.data) || request.resource.data.isLocked == false)) || 
        isStaff() ||
        (isNotBanned() && isValidLikeUpdate(resource, request)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])) ||
        (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'replies', 'lastPost', 'likes']))
      );
      allow delete: if isStaff() || isOwner(resource.data.authorUid);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(resource.data.authorUid) && isValidPost(request.resource.data)) || 
        isStaff() ||
        (isNotBanned() && isValidLikeUpdate(resource, request)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'content', 'editHistory']))
      );
      allow delete: if isStaff() || isOwner(resource.data.authorUid);
    }

    match /activities/{activityId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned();
      allow delete: if isStaff();
    }

    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned();
      allow update, delete: if isStaff();
    }

    match /forum_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /server_stats/{statsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /forum_stats/{statsId} {
      allow read: if true;
      allow update: if isAuthenticated() && (
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalMembers', 'totalPosts', 'totalTopics', 'newestMember', 'discordMembersOnline'])
      );
      allow write: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isStaff());
      allow delete: if isAdmin();
    }
  }
}
